{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://endcord.local/bot-config.schema.json",
  "title": "Endcord Bot Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "discord",
    "plugin_bridge",
    "relay",
    "slash_commands",
    "presence",
    "logging",
    "system_messages"
  ],
  "properties": {
    "discord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "token",
        "guild_id",
        "relay_channel_ids",
        "outbound_channel_id",
        "relay_to_game_enabled",
        "sync_commands_globally",
        "auto_create_webhook",
        "webhook_name"
      ],
      "properties": {
        "token": {
          "type": "string"
        },
        "guild_id": {
          "type": "integer",
          "minimum": 0
        },
        "relay_channel_ids": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "outbound_channel_id": {
          "type": "integer",
          "minimum": 0
        },
        "command_role_ids": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "status_role_ids": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "relay_to_game_enabled": {
          "type": "boolean"
        },
        "sync_commands_globally": {
          "type": "boolean"
        },
        "auto_create_webhook": {
          "type": "boolean"
        },
        "webhook_name": {
          "type": "string",
          "description": "Webhook name to create or reuse in the outbound channel. Avoid the word 'Discord' because Discord rejects it in webhook names."
        }
      }
    },
    "plugin_bridge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base_url",
        "request_timeout_seconds",
        "configure_webhook_on_startup",
        "request_max_retries",
        "request_retry_base_seconds",
        "request_retry_max_seconds"
      ],
      "properties": {
        "base_url": {
          "type": "string",
          "pattern": "^https?://"
        },
        "shared_secret": {
          "type": "string",
          "description": "Optional advanced override. If omitted, the bot reads bot_bridge.shared_secret from the colocated plugin config."
        },
        "request_timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "configure_webhook_on_startup": {
          "type": "boolean"
        },
        "request_max_retries": {
          "type": "integer",
          "minimum": 0
        },
        "request_retry_base_seconds": {
          "type": "number",
          "minimum": 0.1
        },
        "request_retry_max_seconds": {
          "type": "number",
          "minimum": 0.1
        }
      }
    },
    "relay": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "include_attachment_urls",
        "include_jump_url",
        "ignore_bot_messages",
        "ignore_webhook_messages",
        "message_template",
        "attachment_template",
        "jump_url_template",
        "join_separator",
        "max_message_length"
      ],
      "properties": {
        "include_attachment_urls": {
          "type": "boolean"
        },
        "include_jump_url": {
          "type": "boolean"
        },
        "ignore_bot_messages": {
          "type": "boolean"
        },
        "ignore_webhook_messages": {
          "type": "boolean"
        },
        "message_template": {
          "type": "string"
        },
        "attachment_template": {
          "type": "string"
        },
        "jump_url_template": {
          "type": "string"
        },
        "join_separator": {
          "type": "string"
        },
        "max_message_length": {
          "type": "integer",
          "minimum": 32
        }
      }
    },
    "slash_commands": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "ephemeral_responses",
        "status",
        "command",
        "players",
        "ping",
        "configreload"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "ephemeral_responses": {
          "type": "boolean"
        },
        "status": {
          "$ref": "#/$defs/slashCommandRule"
        },
        "command": {
          "$ref": "#/$defs/slashCommandRule"
        },
        "players": {
          "$ref": "#/$defs/slashCommandRule"
        },
        "ping": {
          "$ref": "#/$defs/slashCommandRule"
        },
        "configreload": {
          "$ref": "#/$defs/slashCommandRule"
        }
      }
    },
    "presence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "status",
        "activity_type",
        "activity_text",
        "fallback_text",
        "streaming_url",
        "update_interval_seconds"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "online",
            "idle",
            "dnd",
            "invisible"
          ]
        },
        "activity_type": {
          "type": "string",
          "enum": [
            "playing",
            "streaming",
            "listening",
            "watching",
            "competing",
            "custom"
          ]
        },
        "activity_text": {
          "type": "string"
        },
        "fallback_text": {
          "type": "string"
        },
        "streaming_url": {
          "type": "string"
        },
        "update_interval_seconds": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "log_ignored_messages",
        "log_relay_successes",
        "log_presence_updates"
      ],
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "CRITICAL",
            "ERROR",
            "WARNING",
            "INFO",
            "DEBUG"
          ]
        },
        "log_ignored_messages": {
          "type": "boolean"
        },
        "log_relay_successes": {
          "type": "boolean"
        },
        "log_presence_updates": {
          "type": "boolean"
        }
      }
    },
    "system_messages": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "channel_id",
        "poll_interval_seconds",
        "failure_backoff_seconds",
        "max_backoff_seconds",
        "message_template",
        "max_messages_per_poll"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "channel_id": {
          "type": "integer",
          "minimum": 0
        },
        "poll_interval_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "failure_backoff_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "max_backoff_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "message_template": {
          "type": "string"
        },
        "max_messages_per_poll": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  },
  "$defs": {
    "slashCommandRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "admin_only",
        "role_ids"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "admin_only": {
          "type": "boolean"
        },
        "role_ids": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}
