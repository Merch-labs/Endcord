{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bedrock-discord-bridge.local/bot-config.schema.json",
  "title": "Bedrock Discord Bridge Bot Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "discord",
    "plugin_bridge",
    "relay",
    "slash_commands",
    "presence",
    "logging"
  ],
  "properties": {
    "discord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "token",
        "guild_id",
        "relay_channel_ids",
        "command_role_ids",
        "status_role_ids",
        "relay_to_game_enabled",
        "sync_commands_globally"
      ],
      "properties": {
        "token": {
          "type": "string"
        },
        "guild_id": {
          "type": "integer",
          "minimum": 1
        },
        "relay_channel_ids": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "command_role_ids": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "status_role_ids": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "relay_to_game_enabled": {
          "type": "boolean"
        },
        "sync_commands_globally": {
          "type": "boolean"
        }
      }
    },
    "plugin_bridge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base_url",
        "shared_secret",
        "request_timeout_seconds"
      ],
      "properties": {
        "base_url": {
          "type": "string",
          "pattern": "^https?://"
        },
        "shared_secret": {
          "type": "string"
        },
        "request_timeout_seconds": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "relay": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "include_attachment_urls",
        "include_jump_url",
        "ignore_bot_messages",
        "ignore_webhook_messages",
        "message_template",
        "attachment_template",
        "jump_url_template",
        "join_separator",
        "max_message_length"
      ],
      "properties": {
        "include_attachment_urls": {
          "type": "boolean"
        },
        "include_jump_url": {
          "type": "boolean"
        },
        "ignore_bot_messages": {
          "type": "boolean"
        },
        "ignore_webhook_messages": {
          "type": "boolean"
        },
        "message_template": {
          "type": "string"
        },
        "attachment_template": {
          "type": "string"
        },
        "jump_url_template": {
          "type": "string"
        },
        "join_separator": {
          "type": "string"
        },
        "max_message_length": {
          "type": "integer",
          "minimum": 32
        }
      }
    },
    "slash_commands": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "ephemeral_responses"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "ephemeral_responses": {
          "type": "boolean"
        }
      }
    },
    "presence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "status",
        "activity_type",
        "activity_text",
        "fallback_text",
        "streaming_url",
        "update_interval_seconds"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "online",
            "idle",
            "dnd",
            "invisible"
          ]
        },
        "activity_type": {
          "type": "string",
          "enum": [
            "playing",
            "streaming",
            "listening",
            "watching",
            "competing",
            "custom"
          ]
        },
        "activity_text": {
          "type": "string"
        },
        "fallback_text": {
          "type": "string"
        },
        "streaming_url": {
          "type": "string"
        },
        "update_interval_seconds": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "log_ignored_messages",
        "log_relay_successes",
        "log_presence_updates"
      ],
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "CRITICAL",
            "ERROR",
            "WARNING",
            "INFO",
            "DEBUG"
          ]
        },
        "log_ignored_messages": {
          "type": "boolean"
        },
        "log_relay_successes": {
          "type": "boolean"
        },
        "log_presence_updates": {
          "type": "boolean"
        }
      }
    }
  }
}
