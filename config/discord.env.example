# Copy this file to the plugin data folder as discord.env
# Example: plugins/bedrock_discord_bridge/discord.env

DISCORD_ENABLED=true
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/replace-me

# Optional: public base URL that serves files from the plugin's avatars/ cache.
# Example if you expose plugins/bedrock_discord_bridge/avatars via Caddy or Nginx:
# AVATAR_PUBLIC_BASE_URL=https://cdn.example.com/bedrock-avatars
AVATAR_PUBLIC_BASE_URL=

WEBHOOK_CONNECT_TIMEOUT_MS=3000
WEBHOOK_READ_TIMEOUT_MS=5000
WEBHOOK_WRITE_TIMEOUT_MS=5000
MAX_QUEUE_SIZE=256
AVATAR_SIZE=64
