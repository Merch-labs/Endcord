{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bedrock-discord-bridge.local/plugin-config.schema.json",
  "title": "Bedrock Discord Bridge Plugin Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "config_version",
    "enabled",
    "discord",
    "relay",
    "queue",
    "avatar",
    "bot_bridge",
    "logging"
  ],
  "properties": {
    "config_version": {
      "type": "integer",
      "minimum": 1
    },
    "enabled": {
      "type": "boolean"
    },
    "discord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "webhook_url",
        "allow_runtime_webhook_override",
        "username_template",
        "content_template",
        "system_username_template",
        "join_content_template",
        "quit_content_template",
        "death_content_template",
        "allow_mentions",
        "use_player_avatar_for_system_messages",
        "max_username_length",
        "max_content_length"
      ],
      "properties": {
        "webhook_url": {
          "type": "string"
        },
        "allow_runtime_webhook_override": {
          "type": "boolean"
        },
        "username_template": {
          "type": "string"
        },
        "content_template": {
          "type": "string"
        },
        "system_username_template": {
          "type": "string"
        },
        "join_content_template": {
          "type": "string"
        },
        "quit_content_template": {
          "type": "string"
        },
        "death_content_template": {
          "type": "string"
        },
        "allow_mentions": {
          "type": "boolean"
        },
        "use_player_avatar_for_system_messages": {
          "type": "boolean"
        },
        "max_username_length": {
          "type": "integer",
          "minimum": 1,
          "maximum": 80
        },
        "max_content_length": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2000
        }
      }
    },
    "relay": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minecraft_to_discord_enabled",
        "chat_enabled",
        "join_enabled",
        "quit_enabled",
        "death_enabled"
      ],
      "properties": {
        "minecraft_to_discord_enabled": {
          "type": "boolean"
        },
        "chat_enabled": {
          "type": "boolean"
        },
        "join_enabled": {
          "type": "boolean"
        },
        "quit_enabled": {
          "type": "boolean"
        },
        "death_enabled": {
          "type": "boolean"
        }
      }
    },
    "queue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_size",
        "max_attempts",
        "retry_delay_ms",
        "connect_timeout_ms",
        "read_timeout_ms",
        "write_timeout_ms"
      ],
      "properties": {
        "max_size": {
          "type": "integer",
          "minimum": 1
        },
        "max_attempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "retry_delay_ms": {
          "type": "integer",
          "minimum": 100
        },
        "connect_timeout_ms": {
          "type": "integer",
          "minimum": 100
        },
        "read_timeout_ms": {
          "type": "integer",
          "minimum": 100
        },
        "write_timeout_ms": {
          "type": "integer",
          "minimum": 100
        }
      }
    },
    "avatar": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "provider",
        "provider_url_template",
        "provider_prefer_xuid",
        "provider_render_type",
        "provider_bedrock_username_prefix",
        "size"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "provider": {
          "type": "string",
          "enum": ["tabavatars", "mcheads", "custom"]
        },
        "provider_url_template": {
          "type": "string"
        },
        "provider_prefer_xuid": {
          "type": "boolean"
        },
        "provider_render_type": {
          "type": "string"
        },
        "provider_bedrock_username_prefix": {
          "type": "string"
        },
        "size": {
          "type": "integer",
          "minimum": 8,
          "maximum": 512
        }
      }
    },
    "bot_bridge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "shared_secret",
        "api_route_prefix",
        "allow_local_requests_only",
        "allowed_remote_addresses",
        "inbound_chat_enabled",
        "command_enabled",
        "outbound_system_messages_enabled",
        "inbound_chat_template",
        "inbound_chat_max_length",
        "outbound_system_message_max_batch",
        "outbound_system_message_queue_max_size",
        "request_timeout_ms"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "shared_secret": {
          "type": "string"
        },
        "api_route_prefix": {
          "type": "string"
        },
        "allow_local_requests_only": {
          "type": "boolean"
        },
        "allowed_remote_addresses": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inbound_chat_enabled": {
          "type": "boolean"
        },
        "command_enabled": {
          "type": "boolean"
        },
        "outbound_system_messages_enabled": {
          "type": "boolean"
        },
        "inbound_chat_template": {
          "type": "string"
        },
        "inbound_chat_max_length": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4000
        },
        "outbound_system_message_max_batch": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "outbound_system_message_queue_max_size": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4096
        },
        "request_timeout_ms": {
          "type": "integer",
          "minimum": 250
        }
      }
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "log_filtered_events",
        "log_webhook_successes",
        "log_http_requests",
        "log_inbound_chat",
        "log_remote_commands"
      ],
      "properties": {
        "log_filtered_events": {
          "type": "boolean"
        },
        "log_webhook_successes": {
          "type": "boolean"
        },
        "log_http_requests": {
          "type": "boolean"
        },
        "log_inbound_chat": {
          "type": "boolean"
        },
        "log_remote_commands": {
          "type": "boolean"
        }
      }
    }
  }
}
